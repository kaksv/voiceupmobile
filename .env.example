# Africa's Talking: dashboard username (use "sandbox" for SMS sandbox)
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here

# Public HTTPS base URL of this app (no trailing slash). Used for Voice GetDigits callbacks.
# Example: https://abc123.ngrok.io
PUBLIC_BASE_URL=https://your-public-host.example.com

# HTTP port for local dev (default 3000). Point ngrok at this port: ngrok http 3000
# PORT=3000

# Optional: short Alphanumeric sender ID where your account allows it (omit for default)
# AT_SENDER_ID=
