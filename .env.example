# Africa's Talking: dashboard username (use "sandbox" for SMS sandbox)
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here

# Public HTTPS base URL of this app (no trailing slash). Used for Voice GetDigits callbacks.
# Example: https://abc123.ngrok.io
PUBLIC_BASE_URL=https://your-public-host.example.com

# HTTP port for local dev (default 3000). Point ngrok at this port: ngrok http 3000
# PORT=3000

# Optional: short Alphanumeric sender ID where your account allows it (omit for default)
# AT_SENDER_ID=

# SMS: retries (default 2) and optional AT enqueue=1
# SMS_MAX_ATTEMPTS=2
# SMS_ENQUEUE=false

# If SMS reports success but the handset never receives it, set true so the IVR also reads the digits (pilot only).
# OTP_ALSO_SPEAK_ON_CALL=false

# If AT rejects SMS (HTTP or non-Success recipient), read digits on the call so the user can proceed.
# OTP_SPEAK_IF_SMS_FAILS=true

# When AT_API_KEY is missing, read OTP on the call (local dev).
# OTP_SPEAK_IF_NO_API_KEY=true
