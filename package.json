{
  "name": "africastalking-talk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "build": "tsc",
    "build:web": "npm run build --workspace=frontend",
    "build:all": "npm run build && npm run build:web",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:web": "npm run dev --workspace=frontend"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
